# ─────────────────────────────────────────────────────────────────────────────
# YAKSHA FAQ PORTAL — Environment Variables
#
# QUICK START (local dev):
#   1. Copy this file to .env.local   →   cp .env.example .env.local
#   2. Fill in MONGODB_URI and the three secret keys (see instructions below)
#   3. Leave everything else at its default or blank — the server starts fine
#
# FEATURES enabled by this config:
#   • Search alias engine + query expansion hints  — no extra keys needed
#   • Voice search (Whisper)                       — no extra keys needed
#                                                    (set HUGGINGFACE_API_KEY
#                                                     to skip 1.2 GB download)
#   • AI duplicate-question detection              — requires one AI key below
# ─────────────────────────────────────────────────────────────────────────────

PORT=6767
NODE_ENV=development
CLIENT_URL=http://localhost:5173/

# ── MongoDB ────────────────────────────────────────────────────────────────────
# Option A — Local MongoDB (recommended for local dev, no account needed)
#   Make sure mongod is running on port 27017 (default) or 27012 (team default)
MONGODB_URI=mongodb://127.0.0.1:27012/yaksha
#
# Option B — MongoDB Atlas (cloud, needed for shared/staging environments)
#   https://cloud.mongodb.com → Cluster → Connect → Connect your application
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.z3cgb58.mongodb.net/?appName=Cluster0

# ── Secrets ───────────────────────────────────────────────────────────────────
# Generate each with:  openssl rand -hex 32   (or any 32-char random string)
# Every teammate should generate their OWN values — do not share these.
JWT_SECRET=<generate-with-openssl-rand-hex-32>

# AES-GCM master key for encrypting Zoom tokens and TOTP secrets.
# When unset, falls back to JWT_SECRET (fine for local dev).
ENCRYPTION_MASTER_KEY=<generate-with-openssl-rand-hex-32>

# HMAC secret for OAuth state signing.
# When unset, falls back to JWT_SECRET (fine for local dev).
OAUTH_STATE_SECRET=<generate-with-openssl-rand-hex-32>

# ── HuggingFace (voice search embeddings) ─────────────────────────────────────
# Optional — but strongly recommended to avoid a 1.2 GB local model download.
# When set, the voice transcription pipeline routes through the HF Inference API
# instead of downloading the ONNX model locally.
# Get a free key at https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# v1.68 — H1: dedicated HMAC secret for OAuth state signing.
# Rotate independently of JWT signing. Generate with: openssl rand -hex 32
# When unset, falls back to JWT_SECRET (backwards compat).
OAUTH_STATE_SECRET=

# ── Redis (optional — enables cross-instance cache) ───────────────────────────
# https://console.upstash.com → Create Redis Database → REST API
REDIS_URL=https://<your-db>.upstash.io
REDIS_TOKEN=<your-token>

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# https://sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN=https://<key>@sentry.io/<project>

# ── Zoom OAuth ─────────────────────────────────────────────────────────────────
# https://marketplace.zoom.us → Create User-managed OAuth app
# Required scopes: recording:read, meeting:read:admin
# OAuth redirect:
#   Dev:  http://localhost:6767/api/zoom/auth/callback
#   Prod: https://yaksha-faq-backend.vercel.app/api/zoom/auth/callback
ZOOM_CLIENT_ID=<your-zoom-oauth-client-id>
ZOOM_CLIENT_SECRET=<your-zoom-oauth-client-secret>
# OAuth redirect URI — must match exactly what's in your Zoom App settings
ZOOM_REDIRECT_URI=http://localhost:6767/api/zoom/auth/callback
# Comma-separated regexes — matching meeting topics are skipped
ZOOM_TOPIC_BLACKLIST=

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS — duplicate question detection
# Optional for local dev — the server starts without any key, but AI-powered
# duplicate detection will be disabled until at least one key is set.
# Priority (first configured key wins): Anthropic → OpenAI → Grok → MiniMax
# ─────────────────────────────────────────────────────────────────────────────
#
# ANTHROPIC CLAUDE (recommended)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
#
# OPENAI GPT-4o-mini
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
#
# XAI GROK-3
# https://console.x.ai/
XAI_API_KEY=
#
# MINIMAX TEXT-01 — supports custom vLLM endpoint
# https://platform.minimax.io → Token Plan → API Key
# Override BASE_URL and MODEL to use your own vLLM server instead:
#   MINIMAX_BASE_URL  — defaults to https://api.minimax.io/v1
#   MINIMAX_MODEL     — defaults to MiniMax-Text-01
#   MINIMAX_API_KEY   — required for MiniMax cloud; optional for self-hosted vLLM
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL=

# ── AI Pipeline Overrides ──────────────────────────────────────────────────────
# Per-pipeline AI provider + model. If unset, falls back to the first configured
# global provider (ANTHROPIC > OPENAI > XAI > MINIMAX).
#
# Providers: anthropic | openai | xai | minimax
# Models:    any model the provider supports (e.g. claude-sonnet-4-20250514, gpt-4o-mini,
#            grok-3, MiniMax-Text-01)
#
# FAQ audit pipeline
# FAQ_AUDIT_PROVIDER=anthropic
# FAQ_AUDIT_MODEL=claude-sonnet-4-20250514
#
# Auto-answer pipeline
# AUTO_ANSWER_PROVIDER=anthropic
# AUTO_ANSWER_MODEL=claude-sonnet-4-20250514

# ── Unanswered Question Escalation ────────────────────────────────────────────
UNANSWERED_ESCALATION_DAYS=7
UNANSWERED_ESCALATION_CHECK_MINUTES=60

# ── Cloudinary (image uploads) ────────────────────────────────────────────────
# Required for profile pictures and post attachments.
# For local dev where you don't need image uploads, use the dummy values below
# to pass environment validation — the upload endpoints will fail gracefully.
# https://console.cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=dummy
CLOUDINARY_API_KEY=dummy
CLOUDINARY_API_SECRET=dummy
CLOUDINARY_FOLDER=yaksha
