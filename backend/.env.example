# ─────────────────────────────────────────────────────────────────────────────
# YAKSHA FAQ PORTAL — Environment Variables
# Copy to .env and fill in every value marked with <...>.
# Server will NOT start without at least one AI API key configured.
# ─────────────────────────────────────────────────────────────────────────────

PORT=6767
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# https://cloud.mongodb.com → Cluster → Connect → Connect your application
MONGODB_URI=mongodb+srv=<user>:<password>@cluster0.z3cgb58.mongodb.net/?appName=Cluster0

# ── JWT ─────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=<generate-with-openssl-rand-hex-32>

# ── Redis (optional — enables cross-instance cache) ───────────────────────────
# https://console.upstash.com → Create Redis Database → REST API
REDIS_URL=https://<your-db>.upstash.io
REDIS_TOKEN=<your-token>

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# https://sentry.io → your project → Settings → Client Keys (DSN)
SENTRY_DSN=https://<key>@sentry.io/<project>

# ── Zoom OAuth ─────────────────────────────────────────────────────────────────
# https://marketplace.zoom.us → Create User-managed OAuth app
# Required scopes: recording:read, meeting:read:admin
# OAuth redirect:
#   Dev:  http://localhost:6767/api/zoom/auth/callback
#   Prod: https://yaksha-faq-backend.vercel.app/api/zoom/auth/callback
ZOOM_CLIENT_ID=<your-zoom-client-id>
ZOOM_CLIENT_SECRET=<your-zoom-client-secret>
# OAuth redirect URI — must match exactly what's in your Zoom App settings
ZOOM_REDIRECT_URI=http://localhost:6767/api/zoom/auth/callback
# Comma-separated regexes — matching meeting topics are skipped
ZOOM_TOPIC_BLACKLIST=

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDERS — duplicate question detection
# At least ONE must be set. Server refuses to start without one.
# Priority (first configured key wins): Anthropic → OpenAI → Grok → MiniMax
# ─────────────────────────────────────────────────────────────────────────────
#
# ANTHROPIC CLAUDE (recommended)
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
#
# OPENAI GPT-4o-mini
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
#
# XAI GROK-3
# https://console.x.ai/
XAI_API_KEY=
#
# MINIMAX TEXT-01 — supports custom vLLM endpoint
# https://platform.minimax.io → Token Plan → API Key
# Override BASE_URL and MODEL to use your own vLLM server instead:
#   MINIMAX_BASE_URL  — defaults to https://api.minimax.io/v1
#   MINIMAX_MODEL     — defaults to MiniMax-Text-01
#   MINIMAX_API_KEY   — required for MiniMax cloud; optional for self-hosted vLLM
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODEL=

# ── Unanswered Question Escalation ────────────────────────────────────────────
UNANSWERED_ESCALATION_DAYS=7
UNANSWERED_ESCALATION_CHECK_MINUTES=60