# Vercel deployment: set these in the Vercel dashboard → Environment Variables
# Local development: copy this file to .env and fill in values

# Backend API URL (no trailing slash)
VITE_API_URL=http://localhost:6767/api

# Frontend public URL (used by admin to link back to the user-facing site)
# Leave unset in local dev — code falls back to the current window origin
VITE_PUBLIC_URL=
